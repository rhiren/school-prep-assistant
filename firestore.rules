rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Current no-auth architecture stores only per-student sync documents in Firestore.
    // Allow those specific documents for any generated studentId so profiles and progress
    // can sync across devices without hardcoded student ids.
    match /sync/{documentId} {
      allow read, write: if documentId == "student_roster";
    }

    match /sync_diagnostics/{deviceId} {
      allow read, write: if true;
    }

    match /students/{studentId}/progress/{documentId} {
      allow read, write: if documentId == "current";
    }

    match /students/{studentId}/profile/{documentId} {
      allow read, write: if documentId == "current";
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
